# FILE: .gitignore
# ROLE: Prevent secrets, build artifacts, and local runtime data from entering git
# INSPIRED BY: Polyglot Node + Python + Solidity production repositories
# PERFORMANCE TARGET: Zero credential leaks and reproducible clean clones

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# Environment / secrets
.env
.env.*
!.env.example
backend/.env
frontend/.env
ml-engine/.env
*.pem
*.key
*.crt
*.p12
*.pfx

# Node.js
node_modules/
**/node_modules/
dist/
build/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
coverage/
*.tsbuildinfo

# Vite
frontend/dist/
frontend/.vite/

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.venv/
venv/
env/
ENV/

# ML artifacts and datasets
ml-engine/data/transactions.parquet
ml-engine/saved_models/
ml-engine/**/*.pt
ml-engine/**/*.pth
ml-engine/**/*.pkl
ml-engine/**/*.joblib
ml-engine/**/*.onnx
observability-brain/data/
observability-brain/runtime_models/
observability-brain/**/*.pt
observability-brain/**/*.pth
observability-brain/**/*.pkl
observability-brain/**/*.joblib
observability-brain/**/*.onnx
*.db
*.sqlite
*.sqlite3

# Jupyter
.ipynb_checkpoints/

# Hardhat / blockchain artifacts
Blockchain/artifacts/
Blockchain/cache/
Blockchain/typechain-types/
Blockchain/coverage/
Blockchain/coverage.json
Blockchain/deployed.json
blockchain/artifacts/
blockchain/cache/
blockchain/typechain-types/
blockchain/coverage/
blockchain/coverage.json
blockchain/deployed.json

# Docker runtime
*.pid
*.seed
*.pid.lock
tmp/
temp/

# Local app data
.hardhat-appdata/
.hardhat-local/
backend/uploads/
backend/tmp/
backend/.cache/

# Personal pitch / local notes (do not push)
JP_Morgan_5_Minute_Pitch.txt
*.local.txt
notes/
