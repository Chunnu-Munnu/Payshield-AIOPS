# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL — optional, in-memory fallback works without this)
DATABASE_URL=postgresql://payshield:payshield@localhost:5432/payshield

# Redis (optional — in-memory fallback if not available)
REDIS_URL=redis://localhost:6379

# ML Engine
ML_SERVICE_URL=http://localhost:8000

# Blockchain (Hardhat local node)
BLOCKCHAIN_RPC_URL=http://localhost:8545
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
FRAUD_AUDIT_CONTRACT=
TX_REGISTRY_CONTRACT=
FEDERATED_REGISTRY_CONTRACT=
ALERT_ESCROW_CONTRACT=
IDENTITY_VERIFIER_CONTRACT=

# JWT
JWT_SECRET=payshield-hackathon-secret-change-in-production

# Email Alerts (Gmail — get App Password from Google Account → Security → App Passwords)
# Leave blank to disable emails (everything still works without this)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM_ADDRESS=alerts@payshield.ai
EMAIL_FROM_NAME=PayShield AI Security
DEMO_USER_EMAIL=your-gmail@gmail.com

# App URL (for email links)
APP_BASE_URL=http://localhost:3001

# OTP
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
